#!/usr/bin/env bash
# Plugin-bundled goc wrapper.
#
# Claude Code auto-prepends ${plugin}/bin to the Bash tool's PATH while the
# plugin is enabled, so skill bodies can keep calling plain `goc <verb>`.
# This wrapper resolves the bundled engine via `uv run --project ${PLUGIN_ROOT}`,
# which builds an isolated venv with click + pyyaml on first call (cached
# afterward at ${PLUGIN_ROOT}/.venv).
#
# Requires `uv` on PATH. The fallback path `pipx install game-of-cards`
# remains documented for environments without uv.

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
PLUGIN_ROOT="$(dirname -- "$SCRIPT_DIR")"

if ! command -v uv > /dev/null 2>&1; then
    echo "goc: 'uv' not found on PATH. Install from https://docs.astral.sh/uv/" >&2
    echo "Alternative: 'pipx install game-of-cards' for a global install." >&2
    exit 127
fi

exec uv run --quiet --project "$PLUGIN_ROOT" goc "$@"
