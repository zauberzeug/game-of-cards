# Plugin-mirror trees are byte-for-byte regenerated from the source-of-truth
# by `scripts/sync_plugin_assets.py` (run as a pre-commit hook + CI tripwire).
# The diff content is duplication of changes already visible in `goc/` or
# `goc/templates/skills/`; marking these paths `linguist-generated` tells
# GitHub's review surface to collapse them by default, so reviewers see the
# authored change once instead of N times across the mirrors.
claude-plugin/goc/** linguist-generated=true
codex-plugin/goc/** linguist-generated=true
openclaw-plugin/goc/** linguist-generated=true
claude-plugin/skills/** linguist-generated=true
codex-plugin/skills/** linguist-generated=true
.claude/skills/** linguist-generated=true
.codex/skills/** linguist-generated=true
claude-plugin/hooks/** linguist-generated=true
codex-plugin/hooks/** linguist-generated=true
.claude/hooks/** linguist-generated=true
# esbuild output (`npm run build`), committed so the plugin installs
# without a build step — generated, like the mirrors above.
openclaw-plugin/dist/** linguist-generated=true
# Authored files inside synced/marked trees — carve-outs must follow the
# globs (last matching line wins) so real authored diffs stay reviewable.
claude-plugin/hooks/hooks.json linguist-generated=false
codex-plugin/hooks/hooks.json linguist-generated=false
.claude/skills/tune-cadence/** linguist-generated=false
