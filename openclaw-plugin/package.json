{
  "name": "game-of-cards",
  "version": "0.0.23",
  "description": "Game of Cards skills and hooks — agile work-card methodology for OpenClaw agents. Bundles the goc engine; requires only python3 (3.10+) on PATH.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "author": {
    "name": "Zauberzeug GmbH"
  },
  "homepage": "https://game-of-cards.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/zauberzeug/game-of-cards"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "game-of-cards",
    "goc",
    "kanban",
    "agile",
    "deck",
    "ai-agents"
  ],
  "files": [
    "dist/",
    "index.ts",
    "openclaw.plugin.json",
    "skills/",
    "goc/",
    "tsconfig.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --emitDeclarationOnly && esbuild index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:openclaw --external:openclaw/* --sourcemap",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "engines": {
    "node": ">=22.16"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.24-beta.2"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.32.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.5.0"
  }
}
