+[tool.hatch.version]
+source = "vcs"
+
+[tool.hatch.version.raw-options]
+# At a tagged commit `vX.Y.Z`, emit exactly `X.Y.Z` (no `.dev0`, no patch bump).
+# Between tags, emit `X.Y.Z.devN` so dev wheels are obviously not the release.
+# `no-local-version` drops `+gabc1234` so dev wheels stay PyPI-uploadable if
+# someone happens to run `uv build` between tags.
+version_scheme = "no-guess-dev"
+local_scheme = "no-local-version"
+
 [tool.hatch.build.targets.wheel]
 packages = ["goc"]
 
